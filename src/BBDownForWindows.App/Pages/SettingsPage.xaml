<Page x:Class="BBDownForWindows.App.Pages.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <ScrollViewer><StackPanel Padding="24" Spacing="16" MaxWidth="1280" HorizontalAlignment="Left">
        <StackPanel><TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="默认下载参数、外部工具和任务日志" Opacity="0.65"/></StackPanel>
        <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12"><TextBlock Text="默认下载设置" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <ComboBox Header="视频质量" HorizontalAlignment="Stretch" ItemsSource="{Binding QualityOptions}" SelectedItem="{Binding Settings.Quality, Mode=TwoWay}"/>
                <ComboBox Grid.Column="1" Header="编码" HorizontalAlignment="Stretch" ItemsSource="{Binding EncodingOptions}" SelectedItem="{Binding Settings.Encoding, Mode=TwoWay}"/>
                <ComboBox Grid.Column="2" Header="下载类型" HorizontalAlignment="Stretch" ItemsSource="{Binding DownloadModeOptions}" SelectedItem="{Binding Settings.LegacyAudioOnly, Mode=TwoWay}"/>
                <ComboBox Grid.Column="3" Header="音频格式" HorizontalAlignment="Stretch" ItemsSource="{Binding AudioCodecOptions}" SelectedItem="{Binding Settings.AudioCodec, Mode=TwoWay}"/>
                <ComboBox Grid.Column="4" Header="音频码率" HorizontalAlignment="Stretch" ItemsSource="{Binding AudioBitrateOptions}" SelectedItem="{Binding Settings.LegacyAudioBitratePriority, Mode=TwoWay}"/>
            </Grid>
            <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="下载目录" Text="{Binding Settings.WorkDirectory, Mode=TwoWay}"/><Button Grid.Column="1" Content="浏览…" VerticalAlignment="Bottom" Click="BrowseWorkDir_Click"/></Grid>
            <StackPanel Orientation="Horizontal" Spacing="16"><CheckBox Content="弹幕" IsChecked="{Binding Settings.Danmaku, Mode=TwoWay}"/><CheckBox Content="字幕" IsChecked="{Binding Settings.Subtitle, Mode=TwoWay}"/><CheckBox Content="封面" IsChecked="{Binding Settings.Cover, Mode=TwoWay}"/><CheckBox Content="多线程" IsChecked="{Binding Settings.MultiThread, Mode=TwoWay}"/><CheckBox Content="保存日志" IsChecked="{Binding Settings.SaveTaskLogs, Mode=TwoWay}"/></StackPanel>
        </StackPanel></Border>
        <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12"><TextBlock Text="aria2c" Style="{StaticResource SubtitleTextBlockStyle}"/><CheckBox Content="默认使用 aria2c" IsChecked="{Binding Settings.UseAria2c, Mode=TwoWay}"/>
            <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="aria2c.exe 路径" Text="{Binding Settings.Aria2cPath, Mode=TwoWay}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseAria_Click"/></Grid>
            <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <NumberBox Header="每服务器连接数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2MaxConnection, Mode=TwoWay}"/><NumberBox Grid.Column="1" Header="文件分片数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2Split, Mode=TwoWay}"/><NumberBox Grid.Column="2" Header="同时任务数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2MaxConcurrentDownloads, Mode=TwoWay}"/><NumberBox Grid.Column="3" Header="最小分片 MB" Minimum="1" Maximum="64" Value="{Binding Settings.Aria2MinSplitSize, Mode=TwoWay}"/>
            </Grid>
        </StackPanel></Border>
        <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12"><TextBlock Text="MKVToolNix" Style="{StaticResource SubtitleTextBlockStyle}"/><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="mkvmerge.exe 路径" Text="{Binding Settings.MkvmergePath, Mode=TwoWay}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseMkv_Click"/></Grid><TextBlock Text="{Binding ToolStatus}" FontFamily="Consolas" TextWrapping="Wrap"/></StackPanel></Border>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0"><Button Content="保存设置" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}"/><Button Content="恢复默认" Command="{Binding ResetCommand}"/><Button Content="重新检测工具" Command="{Binding DetectToolsCommand}"/><Button Content="应用到下载页" Click="Apply_Click"/><Button Content="清理本会话进程" Command="{Binding CleanupCommand}"/></StackPanel>
        <InfoBar IsOpen="{Binding HasMessage}" Severity="Informational" Message="{Binding Message}" IsClosable="False"/>
    </StackPanel></ScrollViewer>
</Page>
