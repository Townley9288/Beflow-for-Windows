<Page x:Class="BBDownForWindows.App.Pages.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1100" /></VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0" /></VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ToolPrimaryColumn.Width" Value="*" />
                        <Setter Target="ToolSecondaryColumn.Width" Value="0" />
                        <Setter Target="ToolSecondaryRow.Height" Value="Auto" />
                        <Setter Target="ToolCards.RowSpacing" Value="8" />
                        <Setter Target="MkvCard.(Grid.Column)" Value="0" />
                        <Setter Target="MkvCard.(Grid.Row)" Value="1" />
                        <Setter Target="AccountPrimaryColumn.Width" Value="*" />
                        <Setter Target="AccountSecondaryColumn.Width" Value="0" />
                        <Setter Target="AccountSecondaryRow.Height" Value="Auto" />
                        <Setter Target="AccountPanels.RowSpacing" Value="8" />
                        <Setter Target="TvAccountCard.(Grid.Column)" Value="0" />
                        <Setter Target="TvAccountCard.(Grid.Row)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup>
                <VisualState x:Name="ComfortableSettings">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1100" /></VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="CompactSettings">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0" /></VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DefaultColumn0.Width" Value="*" />
                        <Setter Target="DefaultColumn1.Width" Value="*" />
                        <Setter Target="DefaultColumn2.Width" Value="*" />
                        <Setter Target="DefaultColumn3.Width" Value="0" />
                        <Setter Target="DefaultColumn4.Width" Value="0" />
                        <Setter Target="DefaultSecondaryRow.Height" Value="Auto" />
                        <Setter Target="DefaultAudioCodec.(Grid.Row)" Value="1" />
                        <Setter Target="DefaultAudioCodec.(Grid.Column)" Value="0" />
                        <Setter Target="DefaultAudioBitrate.(Grid.Row)" Value="1" />
                        <Setter Target="DefaultAudioBitrate.(Grid.Column)" Value="1" />
                        <Setter Target="DefaultOptionColumn0.Width" Value="*" />
                        <Setter Target="DefaultOptionColumn1.Width" Value="*" />
                        <Setter Target="DefaultOptionColumn2.Width" Value="*" />
                        <Setter Target="DefaultOptionColumn3.Width" Value="0" />
                        <Setter Target="DefaultOptionColumn4.Width" Value="0" />
                        <Setter Target="DefaultOptionsSecondaryRow.Height" Value="Auto" />
                        <Setter Target="DefaultMultiThread.(Grid.Row)" Value="1" />
                        <Setter Target="DefaultMultiThread.(Grid.Column)" Value="0" />
                        <Setter Target="DefaultSaveLogs.(Grid.Row)" Value="1" />
                        <Setter Target="DefaultSaveLogs.(Grid.Column)" Value="1" />
                        <Setter Target="AriaColumn0.Width" Value="*" />
                        <Setter Target="AriaColumn1.Width" Value="*" />
                        <Setter Target="AriaColumn2.Width" Value="0" />
                        <Setter Target="AriaColumn3.Width" Value="0" />
                        <Setter Target="AriaSecondaryRow.Height" Value="Auto" />
                        <Setter Target="AriaConcurrent.(Grid.Row)" Value="1" />
                        <Setter Target="AriaConcurrent.(Grid.Column)" Value="0" />
                        <Setter Target="AriaMinSplit.(Grid.Row)" Value="1" />
                        <Setter Target="AriaMinSplit.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ScrollViewer x:Name="SettingsScrollViewer" HorizontalScrollBarVisibility="Disabled" SizeChanged="SettingsScrollViewer_SizeChanged"><StackPanel x:Name="SettingsContent" Padding="24,16" Spacing="12" HorizontalAlignment="Left">
        <StackPanel><TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="默认下载参数、外部工具和任务日志" Opacity="0.65"/></StackPanel>
        <StackPanel Spacing="8">
        <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="B 站账号" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="分别验证 WEB 与 TV 登录数据；两者可以登录不同账号" Opacity="0.65" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding LastAccountCheckText}" Opacity="0.55" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="刷新状态" Command="{Binding RefreshAccountsCommand}" VerticalAlignment="Top"/>
                </Grid>

                <Grid x:Name="AccountPanels" ColumnSpacing="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="AccountSecondaryRow" Height="0"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition x:Name="AccountPrimaryColumn" Width="*"/><ColumnDefinition x:Name="AccountSecondaryColumn" Width="*"/></Grid.ColumnDefinitions>
                    <Border Padding="16" CornerRadius="12" Background="#147C3AED" BorderBrush="#667C3AED" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="28" Background="#247C3AED">
                                    <Grid><FontIcon Glyph="&#xE77B;" FontSize="24" Foreground="#FF7C3AED"/><Image Source="{Binding WebAccount.AvatarUrl}" Stretch="UniformToFill"/></Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding WebAccount.ChannelTitle}" FontWeight="SemiBold" FontSize="16" Foreground="#FF7C3AED"/>
                                    <TextBlock Text="{Binding WebAccount.ChannelDescription}" Opacity="0.6" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding WebAccount.DisplayName}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding WebAccount.UserIdText}" Opacity="0.7"/><TextBlock Text="{Binding WebAccount.DetailText}" Opacity="0.7"/></StackPanel>
                                    <TextBlock Text="{Binding WebAccount.ExpiryText}" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding WebAccount.LoginButtonText}" Command="{Binding LoginWebCommand}" VerticalAlignment="Top"/>
                            </Grid>
                            <InfoBar IsOpen="True" IsClosable="False" Severity="{Binding WebAccount.Severity}" Title="{Binding WebAccount.StatusTitle}" Message="{Binding WebAccount.StatusMessage}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="TvAccountCard" Grid.Column="1" Padding="16" CornerRadius="12" Background="#140891B2" BorderBrush="#660891B2" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="28" Background="#240891B2">
                                    <Grid><FontIcon Glyph="&#xE77B;" FontSize="24" Foreground="#FF0891B2"/><Image Source="{Binding TvAccount.AvatarUrl}" Stretch="UniformToFill"/></Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding TvAccount.ChannelTitle}" FontWeight="SemiBold" FontSize="16" Foreground="#FF0891B2"/>
                                    <TextBlock Text="{Binding TvAccount.ChannelDescription}" Opacity="0.6" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TvAccount.DisplayName}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding TvAccount.UserIdText}" Opacity="0.7"/><TextBlock Text="{Binding TvAccount.DetailText}" Opacity="0.7"/></StackPanel>
                                    <TextBlock Text="{Binding TvAccount.ExpiryText}" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding TvAccount.LoginButtonText}" Command="{Binding LoginTvCommand}" VerticalAlignment="Top"/>
                            </Grid>
                            <InfoBar IsOpen="True" IsClosable="False" Severity="{Binding TvAccount.Severity}" Title="{Binding TvAccount.StatusTitle}" Message="{Binding TvAccount.StatusMessage}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel x:Name="QrPanel" Visibility="Collapsed" HorizontalAlignment="Center" Spacing="8">
                    <Image x:Name="QrImage" Width="180" Height="180" Stretch="Uniform"/>
                    <TextBlock x:Name="QrStatus" Text="等待二维码生成…" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Content="取消登录" Command="{Binding Console.CancelCommand}" HorizontalAlignment="Center"/>
                </StackPanel>
                <InfoBar IsOpen="{Binding HasLoginMessage}" Visibility="{Binding LoginMessageVisibility}" IsClosable="False" Severity="{Binding LoginMessageSeverity}" Message="{Binding LoginMessage}"/>
            </StackPanel>
        </Border>
        <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="默认下载设置" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="恢复默认" Command="{Binding ResetDownloadCommand}"/>
                    <Button Content="应用到下载页" Click="Apply_Click"/>
                    <Button Content="保存" Command="{Binding SaveDownloadCommand}" Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>
            </Grid>
            <Grid ColumnSpacing="12" RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="DefaultSecondaryRow" Height="0"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition x:Name="DefaultColumn0" Width="*"/><ColumnDefinition x:Name="DefaultColumn1" Width="*"/><ColumnDefinition x:Name="DefaultColumn2" Width="*"/><ColumnDefinition x:Name="DefaultColumn3" Width="*"/><ColumnDefinition x:Name="DefaultColumn4" Width="*"/></Grid.ColumnDefinitions>
                <ComboBox Header="默认画质规则" HorizontalAlignment="Stretch" ItemsSource="{Binding QualityOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding Settings.VideoQualityRule, Mode=TwoWay}"/>
                <ComboBox Grid.Column="1" Header="编码" HorizontalAlignment="Stretch" ItemsSource="{Binding EncodingOptions}" SelectedItem="{Binding Settings.Encoding, Mode=TwoWay}"/>
                <ComboBox Grid.Column="2" Header="下载类型" HorizontalAlignment="Stretch" ItemsSource="{Binding DownloadModeOptions}" SelectedItem="{Binding Settings.LegacyAudioOnly, Mode=TwoWay}"/>
                <ComboBox x:Name="DefaultAudioCodec" Grid.Column="3" Header="音频格式" HorizontalAlignment="Stretch" ItemsSource="{Binding AudioCodecOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding Settings.AudioCodec, Mode=TwoWay}"/>
                <ComboBox x:Name="DefaultAudioBitrate" Grid.Column="4" Header="音频码率" HorizontalAlignment="Stretch" ItemsSource="{Binding AudioBitrateOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding Settings.LegacyAudioBitratePriority, Mode=TwoWay}"/>
            </Grid>
            <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="下载目录" Text="{Binding Settings.WorkDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="浏览…" VerticalAlignment="Bottom" Click="BrowseWorkDir_Click"/></Grid>
            <Grid ColumnSpacing="12" RowSpacing="6"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="DefaultOptionsSecondaryRow" Height="0"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition x:Name="DefaultOptionColumn0" Width="Auto"/><ColumnDefinition x:Name="DefaultOptionColumn1" Width="Auto"/><ColumnDefinition x:Name="DefaultOptionColumn2" Width="Auto"/><ColumnDefinition x:Name="DefaultOptionColumn3" Width="Auto"/><ColumnDefinition x:Name="DefaultOptionColumn4" Width="Auto"/></Grid.ColumnDefinitions>
                <CheckBox Content="弹幕" IsChecked="{Binding Settings.Danmaku, Mode=TwoWay}"/><CheckBox x:Name="DefaultSubtitle" Grid.Column="1" Content="字幕" IsChecked="{Binding Settings.Subtitle, Mode=TwoWay}"/><CheckBox x:Name="DefaultCover" Grid.Column="2" Content="封面" IsChecked="{Binding Settings.Cover, Mode=TwoWay}"/><CheckBox x:Name="DefaultMultiThread" Grid.Column="3" Content="多线程" IsChecked="{Binding Settings.MultiThread, Mode=TwoWay}"/><CheckBox x:Name="DefaultSaveLogs" Grid.Column="4" Content="保存日志" IsChecked="{Binding Settings.SaveTaskLogs, Mode=TwoWay}"/>
            </Grid>
        </StackPanel></Border>
        <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="影视重命名" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="保存" Command="{Binding SaveRenameCommand}" Style="{StaticResource AccentButtonStyle}"/>
                </Grid>
                <TextBlock Text="重命名功能通过 TMDB 获取中英文片名、年份和剧集名称，需要有效的 API Key 与网络连接。" Opacity="0.65" TextWrapping="Wrap"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <PasswordBox Header="TMDB API Key" Password="{Binding RenameSettings.TmdbApiKey, Mode=TwoWay}" PasswordRevealMode="Peek" PlaceholderText="输入自己的 TMDB v3 API Key"/>
                    <TextBox Grid.Column="1" Header="HTTP 代理（可选）" Text="{Binding RenameSettings.ProxyUrl, Mode=TwoWay}" PlaceholderText="例如 http://127.0.0.1:7890"/>
                    <Button Grid.Column="2" Content="验证 Key" Command="{Binding ValidateTmdbCommand}" VerticalAlignment="Bottom"/>
                </Grid>
                <TextBlock Text="密钥仅保存在本机 Beflow 数据目录，不写入任务日志、重命名历史或下载历史。" Opacity="0.55" FontSize="12"/>
            </StackPanel>
        </Border>
        <Grid ColumnSpacing="12" Margin="0,4,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="外部工具" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="配置下载与多音轨封装所需的辅助工具" Opacity="0.65"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="重新检测工具" Command="{Binding DetectToolsCommand}"/>
                <Button Content="清理本会话进程" Command="{Binding CleanupCommand}"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="ToolCards" ColumnSpacing="16">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="ToolSecondaryRow" Height="0"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition x:Name="ToolPrimaryColumn" Width="3*"/><ColumnDefinition x:Name="ToolSecondaryColumn" Width="2*"/></Grid.ColumnDefinitions>
            <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="aria2c" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="保存" Command="{Binding SaveAriaCommand}" Style="{StaticResource AccentButtonStyle}"/>
                </Grid>
                <CheckBox Content="默认使用 aria2c" IsChecked="{Binding Settings.UseAria2c, Mode=TwoWay}"/>
                <CheckBox Content="根据流大小自动优化连接数与分片数" IsChecked="{Binding Settings.Aria2AutoTune, Mode=TwoWay}"/>
                <TextBlock Text="开启后使用 4/8/16 档自动调优，下面的连接数、分片数和同时任务数作为上限；关闭后直接使用填写值。" Opacity="0.65" TextWrapping="Wrap"/>
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="aria2c.exe 路径" Text="{Binding Settings.Aria2cPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseAria_Click"/></Grid>
                <Grid ColumnSpacing="12" RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="AriaSecondaryRow" Height="0"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition x:Name="AriaColumn0" Width="*"/><ColumnDefinition x:Name="AriaColumn1" Width="*"/><ColumnDefinition x:Name="AriaColumn2" Width="*"/><ColumnDefinition x:Name="AriaColumn3" Width="*"/></Grid.ColumnDefinitions>
                    <NumberBox Header="最大连接数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2MaxConnection, Mode=TwoWay}"/><NumberBox Grid.Column="1" Header="最大分片数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2Split, Mode=TwoWay}"/><NumberBox x:Name="AriaConcurrent" Grid.Column="2" Header="最大同时任务数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2MaxConcurrentDownloads, Mode=TwoWay}"/><NumberBox x:Name="AriaMinSplit" Grid.Column="3" Header="最小分片 MB" Minimum="1" Maximum="64" Value="{Binding Settings.Aria2MinSplitSize, Mode=TwoWay}"/>
                </Grid>
            </StackPanel></Border>
            <Border x:Name="MkvCard" Grid.Column="1" Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="MKVToolNix" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="保存" Command="{Binding SaveMkvCommand}" Style="{StaticResource AccentButtonStyle}"/>
                </Grid>
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="mkvmerge.exe 路径" Text="{Binding Settings.MkvmergePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseMkv_Click"/></Grid><TextBlock Text="{Binding ToolStatus}" FontFamily="Consolas" TextWrapping="Wrap"/>
            </StackPanel></Border>
        </Grid>
        <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="14">
                <TextBlock Text="便捷输入" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Grid ColumnSpacing="12" RowSpacing="3">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <FontIcon Grid.RowSpan="2" Glyph="&#xE77F;" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="监听剪贴板" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="检测到 B 站链接、BV、AV、EP 或 SS 号后，自动激活下载页并解析全部集。" Opacity="0.6" TextWrapping="Wrap"/>
                    <ToggleSwitch Grid.RowSpan="2" Grid.Column="2" IsOn="{Binding Settings.MonitorClipboard, Mode=TwoWay}" Toggled="ClipboardMonitoring_Toggled" VerticalAlignment="Center" AutomationProperties.Name="监听剪贴板"/>
                </Grid>
                <Grid ColumnSpacing="12" RowSpacing="3">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <FontIcon Grid.RowSpan="2" Glyph="&#xE7C9;" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="监听拖拽链接" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="允许把 B 站链接拖入下载页或多音轨来源输入框；关闭后不再接受链接拖放。" Opacity="0.6" TextWrapping="Wrap"/>
                    <ToggleSwitch Grid.RowSpan="2" Grid.Column="2" IsOn="{Binding Settings.MonitorDragLinks, Mode=TwoWay}" Toggled="DragLinkMonitoring_Toggled" VerticalAlignment="Center" AutomationProperties.Name="监听拖拽链接"/>
                </Grid>
            </StackPanel>
        </Border>
        <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="软件更新" Style="{StaticResource SubtitleTextBlockStyle}"/><TextBlock Text="每天启动时最多检查一次 GitHub 稳定版，不会自动下载安装。" Opacity="0.65" TextWrapping="Wrap"/></StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ToggleSwitch Header="启动时检查" IsOn="{Binding Settings.CheckUpdatesOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                    <Button Content="保存" Command="{Binding SaveUpdateCommand}" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        </StackPanel>
        </StackPanel></ScrollViewer>
        <InfoBar x:Name="SettingsNotification"
                 IsOpen="{Binding HasMessage}"
                 Visibility="{Binding MessageVisibility}"
                 Severity="{Binding MessageSeverity}"
                 Message="{Binding Message}"
                 IsClosable="True"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 MaxWidth="720"
                 MinWidth="360"
                 Margin="24,20,24,0"
                 Canvas.ZIndex="20"
                 Closed="SettingsNotification_Closed"/>
    </Grid>
</Page>
