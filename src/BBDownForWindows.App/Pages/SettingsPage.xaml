<Page x:Class="BBDownForWindows.App.Pages.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1400" /></VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0" /></VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ToolPrimaryColumn.Width" Value="*" />
                        <Setter Target="ToolSecondaryColumn.Width" Value="0" />
                        <Setter Target="ToolSecondaryRow.Height" Value="Auto" />
                        <Setter Target="ToolCards.RowSpacing" Value="16" />
                        <Setter Target="MkvCard.(Grid.Column)" Value="0" />
                        <Setter Target="MkvCard.(Grid.Row)" Value="1" />
                        <Setter Target="AccountPrimaryColumn.Width" Value="*" />
                        <Setter Target="AccountSecondaryColumn.Width" Value="0" />
                        <Setter Target="AccountSecondaryRow.Height" Value="Auto" />
                        <Setter Target="AccountPanels.RowSpacing" Value="16" />
                        <Setter Target="TvAccountCard.(Grid.Column)" Value="0" />
                        <Setter Target="TvAccountCard.(Grid.Row)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ScrollViewer x:Name="SettingsScrollViewer" HorizontalScrollBarVisibility="Disabled" SizeChanged="SettingsScrollViewer_SizeChanged"><StackPanel x:Name="SettingsContent" Padding="24" Spacing="16" MaxWidth="1600" HorizontalAlignment="Left">
        <StackPanel><TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="默认下载参数、外部工具和任务日志" Opacity="0.65"/></StackPanel>
        <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="B 站账号" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="分别验证 WEB 与 TV 登录数据；两者可以登录不同账号" Opacity="0.65" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding LastAccountCheckText}" Opacity="0.55" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="刷新状态" Command="{Binding RefreshAccountsCommand}" VerticalAlignment="Top"/>
                </Grid>

                <Grid x:Name="AccountPanels" ColumnSpacing="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="AccountSecondaryRow" Height="0"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition x:Name="AccountPrimaryColumn" Width="*"/><ColumnDefinition x:Name="AccountSecondaryColumn" Width="*"/></Grid.ColumnDefinitions>
                    <Border Padding="14" CornerRadius="8" Background="{ThemeResource ControlFillColorDefaultBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="28" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                    <Grid><FontIcon Glyph="&#xE77B;" FontSize="24"/><Image Source="{Binding WebAccount.AvatarUrl}" Stretch="UniformToFill"/></Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding WebAccount.ChannelTitle}" FontWeight="SemiBold" FontSize="16"/>
                                    <TextBlock Text="{Binding WebAccount.ChannelDescription}" Opacity="0.6" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding WebAccount.DisplayName}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding WebAccount.UserIdText}" Opacity="0.7"/><TextBlock Text="{Binding WebAccount.DetailText}" Opacity="0.7"/></StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding WebAccount.LoginButtonText}" Command="{Binding LoginWebCommand}" VerticalAlignment="Top"/>
                            </Grid>
                            <InfoBar IsOpen="True" IsClosable="False" Severity="{Binding WebAccount.Severity}" Title="{Binding WebAccount.StatusTitle}" Message="{Binding WebAccount.StatusMessage}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="TvAccountCard" Grid.Column="1" Padding="14" CornerRadius="8" Background="{ThemeResource ControlFillColorDefaultBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="28" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                    <Grid><FontIcon Glyph="&#xE77B;" FontSize="24"/><Image Source="{Binding TvAccount.AvatarUrl}" Stretch="UniformToFill"/></Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding TvAccount.ChannelTitle}" FontWeight="SemiBold" FontSize="16"/>
                                    <TextBlock Text="{Binding TvAccount.ChannelDescription}" Opacity="0.6" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TvAccount.DisplayName}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding TvAccount.UserIdText}" Opacity="0.7"/><TextBlock Text="{Binding TvAccount.DetailText}" Opacity="0.7"/></StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding TvAccount.LoginButtonText}" Command="{Binding LoginTvCommand}" VerticalAlignment="Top"/>
                            </Grid>
                            <InfoBar IsOpen="True" IsClosable="False" Severity="{Binding TvAccount.Severity}" Title="{Binding TvAccount.StatusTitle}" Message="{Binding TvAccount.StatusMessage}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel x:Name="QrPanel" Visibility="Collapsed" HorizontalAlignment="Center" Spacing="8">
                    <Image x:Name="QrImage" Width="180" Height="180" Stretch="Uniform"/>
                    <TextBlock x:Name="QrStatus" Text="等待二维码生成…" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Content="取消登录" Command="{Binding Console.CancelCommand}" HorizontalAlignment="Center"/>
                </StackPanel>
                <InfoBar IsOpen="{Binding HasLoginMessage}" IsClosable="False" Severity="{Binding LoginMessageSeverity}" Message="{Binding LoginMessage}"/>
            </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12"><TextBlock Text="默认下载设置" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <ComboBox Header="视频质量" HorizontalAlignment="Stretch" ItemsSource="{Binding QualityOptions}" SelectedItem="{Binding Settings.Quality, Mode=TwoWay}"/>
                <ComboBox Grid.Column="1" Header="编码" HorizontalAlignment="Stretch" ItemsSource="{Binding EncodingOptions}" SelectedItem="{Binding Settings.Encoding, Mode=TwoWay}"/>
                <ComboBox Grid.Column="2" Header="下载类型" HorizontalAlignment="Stretch" ItemsSource="{Binding DownloadModeOptions}" SelectedItem="{Binding Settings.LegacyAudioOnly, Mode=TwoWay}"/>
                <ComboBox Grid.Column="3" Header="音频格式" HorizontalAlignment="Stretch" ItemsSource="{Binding AudioCodecOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding Settings.AudioCodec, Mode=TwoWay}"/>
                <ComboBox Grid.Column="4" Header="音频码率" HorizontalAlignment="Stretch" ItemsSource="{Binding AudioBitrateOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding Settings.LegacyAudioBitratePriority, Mode=TwoWay}"/>
            </Grid>
            <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="下载目录" Text="{Binding Settings.WorkDirectory, Mode=TwoWay}"/><Button Grid.Column="1" Content="浏览…" VerticalAlignment="Bottom" Click="BrowseWorkDir_Click"/></Grid>
            <StackPanel Orientation="Horizontal" Spacing="16"><CheckBox Content="弹幕" IsChecked="{Binding Settings.Danmaku, Mode=TwoWay}"/><CheckBox Content="字幕" IsChecked="{Binding Settings.Subtitle, Mode=TwoWay}"/><CheckBox Content="封面" IsChecked="{Binding Settings.Cover, Mode=TwoWay}"/><CheckBox Content="多线程" IsChecked="{Binding Settings.MultiThread, Mode=TwoWay}"/><CheckBox Content="保存日志" IsChecked="{Binding Settings.SaveTaskLogs, Mode=TwoWay}"/></StackPanel>
        </StackPanel></Border>
        <Grid x:Name="ToolCards" ColumnSpacing="16">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="ToolSecondaryRow" Height="0"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition x:Name="ToolPrimaryColumn" Width="3*"/><ColumnDefinition x:Name="ToolSecondaryColumn" Width="2*"/></Grid.ColumnDefinitions>
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12"><TextBlock Text="aria2c" Style="{StaticResource SubtitleTextBlockStyle}"/><CheckBox Content="默认使用 aria2c" IsChecked="{Binding Settings.UseAria2c, Mode=TwoWay}"/>
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="aria2c.exe 路径" Text="{Binding Settings.Aria2cPath, Mode=TwoWay}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseAria_Click"/></Grid>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <NumberBox Header="每服务器连接数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2MaxConnection, Mode=TwoWay}"/><NumberBox Grid.Column="1" Header="文件分片数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2Split, Mode=TwoWay}"/><NumberBox Grid.Column="2" Header="同时任务数" Minimum="1" Maximum="32" Value="{Binding Settings.Aria2MaxConcurrentDownloads, Mode=TwoWay}"/><NumberBox Grid.Column="3" Header="最小分片 MB" Minimum="1" Maximum="64" Value="{Binding Settings.Aria2MinSplitSize, Mode=TwoWay}"/>
                </Grid>
            </StackPanel></Border>
            <Border x:Name="MkvCard" Grid.Column="1" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12"><TextBlock Text="MKVToolNix" Style="{StaticResource SubtitleTextBlockStyle}"/><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="mkvmerge.exe 路径" Text="{Binding Settings.MkvmergePath, Mode=TwoWay}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseMkv_Click"/></Grid><TextBlock Text="{Binding ToolStatus}" FontFamily="Consolas" TextWrapping="Wrap"/></StackPanel></Border>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0"><Button Content="保存设置" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}"/><Button Content="恢复默认" Command="{Binding ResetCommand}"/><Button Content="重新检测工具" Command="{Binding DetectToolsCommand}"/><Button Content="应用到下载页" Click="Apply_Click"/><Button Content="清理本会话进程" Command="{Binding CleanupCommand}"/></StackPanel>
        <InfoBar IsOpen="{Binding HasMessage}" Severity="Informational" Message="{Binding Message}" IsClosable="False" Margin="16,0,0,0"/>
        </StackPanel></ScrollViewer>
    </Grid>
</Page>
