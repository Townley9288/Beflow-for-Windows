<Page
    x:Class="BBDownForWindows.App.Pages.RenameHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:BBDownForWindows.Core"
    DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16" Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="重命名历史" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="查看文件名变更、撤销记录并管理历史" Opacity="0.65"/>
                </StackPanel>
                <Button Grid.Column="1" Content="返回重命名" Click="BackToRename_Click" VerticalAlignment="Center"/>
            </Grid>

            <InfoBar IsOpen="{Binding HasMessage}" Visibility="{Binding MessageVisibility}" IsClosable="False" Severity="{Binding MessageSeverity}" Message="{Binding Message}"/>

            <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="搜索片名、目录或模板" Text="{Binding HistorySearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="刷新" Click="Refresh_Click"/>
                        <Button Grid.Column="2" Content="查看详情" Click="HistoryDetail_Click"/>
                        <Button Grid.Column="3" Content="撤销所选" Click="UndoHistory_Click" IsEnabled="{Binding CanUndoSelectedHistory}"/>
                        <Button Grid.Column="4" Content="删除记录" Click="DeleteHistory_Click"/>
                    </Grid>

                    <ListView ItemsSource="{Binding HistoryRecords}" SelectedItem="{Binding SelectedHistory, Mode=TwoWay}" MinHeight="460" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="core:RenameHistoryRecord">
                                <Grid Padding="8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="170"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2"><TextBlock Text="{x:Bind DisplayTitle}" FontWeight="SemiBold"/><TextBlock Text="{x:Bind DirectoryPath}" Opacity="0.55" TextTrimming="CharacterEllipsis"/></StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind TemplateName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind TimestampText}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind StateText}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Button Content="清空历史" Click="ClearHistory_Click"/>
                        <Button Grid.Column="2" Content="上一页" Click="HistoryPrevious_Click" IsEnabled="{Binding CanPreviousHistoryPage}"/>
                        <TextBlock Grid.Column="3" Text="{Binding HistoryPageText}" VerticalAlignment="Center"/>
                        <Button Grid.Column="4" Content="下一页" Click="HistoryNext_Click" IsEnabled="{Binding CanNextHistoryPage}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
