<Page x:Class="BBDownForWindows.App.Pages.HistoryPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="using:BBDownForWindows.Core" DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Grid Padding="24" RowSpacing="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="历史" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="恢复下载配置并查看持久任务日志" Opacity="0.65"/></StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"><Button Content="刷新" Command="{Binding ReloadCommand}"/><Button Content="补全旧记录标题" Command="{Binding RefreshTitlesCommand}"/><Button Content="删除" Command="{Binding DeleteCommand}"/><Button Content="清空全部" Click="Clear_Click"/></StackPanel>
        <ListView Grid.Row="2" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord, Mode=TwoWay}" SelectionMode="Single">
            <ListView.ItemTemplate><DataTemplate x:DataType="core:HistoryRecord"><Grid Padding="8" ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/><TextBlock Text="{x:Bind Url}" TextTrimming="CharacterEllipsis" Opacity="0.65"/><TextBlock Text="{x:Bind TaskType}" Opacity="0.65"/></StackPanel><TextBlock Grid.Column="1" Text="{x:Bind TimestampText}" HorizontalAlignment="Right"/></Grid></DataTemplate></ListView.ItemTemplate>
        </ListView>
        <Grid Grid.Row="3"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Content="上一页" Command="{Binding PreviousPageCommand}"/><Button Grid.Column="1" Content="下一页" Command="{Binding NextPageCommand}" Margin="8,0,0,0"/><TextBlock Grid.Column="2" Text="{Binding PageText}" VerticalAlignment="Center" HorizontalAlignment="Center"/><Button Grid.Column="3" Content="查看日志" Click="ViewLog_Click"/><Button Grid.Column="4" Content="加载任务" Style="{StaticResource AccentButtonStyle}" Margin="8,0,0,0" Click="Restore_Click"/>
        </Grid>
    </Grid>
</Page>
