<Page
    x:Class="BBDownForWindows.App.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BBDownForWindows.App.Controls"
    xmlns:core="using:BBDownForWindows.Core"
    NavigationCacheMode="Required">
    <Grid Padding="24,16" RowSpacing="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="历史记录" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="查看下载与重命名记录，恢复任务配置或撤销文件名变更" Opacity="0.65"/>
        </StackPanel>

        <TabView x:Name="HistoryTabs" Grid.Row="1" IsAddTabButtonVisible="False" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <TabViewItem Header="下载记录" IsClosable="False">
                <Grid Padding="0,8,0,0" RowSpacing="12" DataContext="{x:Bind ViewModel, Mode=OneWay}">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="刷新" Command="{Binding ReloadCommand}"/>
                            <Button Content="补全旧记录标题" Command="{Binding RefreshTitlesCommand}"/>
                            <Button Content="删除" Command="{Binding DeleteCommand}"/>
                            <Button Content="清空全部" Click="Clear_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                    <ListView Grid.Row="1" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord, Mode=TwoWay}" SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="core:HistoryRecord">
                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid Padding="8" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Url}" TextTrimming="CharacterEllipsis" Opacity="0.65"/>
                                        <ItemsControl ItemsSource="{x:Bind SpecificationTags}" Margin="0,4,0,2">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><controls:VariableWrapPanel HorizontalSpacing="6" VerticalSpacing="6"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Border Padding="10,4" CornerRadius="12" Background="#182563EB" BorderBrush="#402563EB" BorderThickness="1" HorizontalAlignment="Left">
                                                        <TextBlock Text="{x:Bind}" Foreground="#FF60A5FA" FontSize="12" FontWeight="SemiBold" TextWrapping="NoWrap"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TaskTypeText}" HorizontalAlignment="Right" Opacity="0.65"/>
                                        <TextBlock Text="{x:Bind TimestampText}" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <Grid MinWidth="720">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Button Content="上一页" Command="{Binding PreviousPageCommand}"/>
                            <Button Grid.Column="1" Content="下一页" Command="{Binding NextPageCommand}" Margin="8,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding PageText}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Button Grid.Column="3" Content="查看详情" Click="ViewDetails_Click"/>
                            <Button Grid.Column="4" Content="查看日志" Margin="8,0,0,0" Click="ViewLog_Click"/>
                            <Button Grid.Column="5" Content="加载任务" Style="{StaticResource AccentButtonStyle}" Margin="8,0,0,0" Click="Restore_Click"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="重命名记录" IsClosable="False">
                <Grid Padding="0,8,0,0" RowSpacing="12" DataContext="{x:Bind RenameViewModel, Mode=OneWay}">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <InfoBar IsOpen="{Binding HasMessage}" Visibility="{Binding MessageVisibility}" IsClosable="False" Severity="{Binding MessageSeverity}" Message="{Binding Message}"/>
                    <Border Grid.Row="1" Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" VerticalAlignment="Stretch">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <Grid MinWidth="860" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="搜索片名、目录或模板" Text="{Binding HistorySearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="刷新" Click="RenameRefresh_Click"/>
                                    <Button Grid.Column="2" Content="查看详情" Click="RenameHistoryDetail_Click"/>
                                    <Button Grid.Column="3" Content="撤销所选" Click="RenameUndoHistory_Click" IsEnabled="{Binding CanUndoSelectedHistory}"/>
                                    <Button Grid.Column="4" Content="删除记录" Click="RenameDeleteHistory_Click"/>
                                    <Button Grid.Column="5" Content="返回重命名" Click="BackToRename_Click"/>
                                </Grid>
                            </ScrollViewer>
                            <ListView Grid.Row="1" ItemsSource="{Binding HistoryRecords}" SelectedItem="{Binding SelectedHistory, Mode=TwoWay}" SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="core:RenameHistoryRecord">
                                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid Padding="8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="170"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2"><TextBlock Text="{x:Bind DisplayTitle}" FontWeight="SemiBold"/><TextBlock Text="{x:Bind DirectoryPath}" Opacity="0.55" TextTrimming="CharacterEllipsis"/></StackPanel>
                                            <TextBlock Grid.Column="1" Text="{x:Bind TemplateName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind TimestampText}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind StateText}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Grid Grid.Row="2" ColumnSpacing="8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Button Content="清空历史" Click="RenameClearHistory_Click"/>
                                <Button Grid.Column="2" Content="上一页" Click="RenameHistoryPrevious_Click" IsEnabled="{Binding CanPreviousHistoryPage}"/>
                                <TextBlock Grid.Column="3" Text="{Binding HistoryPageText}" VerticalAlignment="Center"/>
                                <Button Grid.Column="4" Content="下一页" Click="RenameHistoryNext_Click" IsEnabled="{Binding CanNextHistoryPage}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>
