<Page x:Class="BBDownForWindows.App.Pages.HistoryPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="using:BBDownForWindows.Core" DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Grid Padding="24" RowSpacing="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="下载历史" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="恢复下载与封装配置并查看持久任务日志" Opacity="0.65"/></StackPanel>
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="刷新" Command="{Binding ReloadCommand}"/><Button Content="补全旧记录标题" Command="{Binding RefreshTitlesCommand}"/><Button Content="删除" Command="{Binding DeleteCommand}"/><Button Content="清空全部" Click="Clear_Click"/></StackPanel></ScrollViewer>
        <ListView Grid.Row="2" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord, Mode=TwoWay}" SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:HistoryRecord">
                    <Grid Padding="8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Url}" TextTrimming="CharacterEllipsis" Opacity="0.65"/>
                            <ItemsControl ItemsSource="{x:Bind SpecificationTags}" Margin="0,4,0,2">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="6"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border Padding="10,4" CornerRadius="12" Background="#182563EB" BorderBrush="#402563EB" BorderThickness="1">
                                            <TextBlock Text="{x:Bind}" Foreground="#FF60A5FA" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Bind TaskType}" Opacity="0.65"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Bind TimestampText}" HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"><Grid MinWidth="720"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Content="上一页" Command="{Binding PreviousPageCommand}"/><Button Grid.Column="1" Content="下一页" Command="{Binding NextPageCommand}" Margin="8,0,0,0"/><TextBlock Grid.Column="2" Text="{Binding PageText}" VerticalAlignment="Center" HorizontalAlignment="Center"/><Button Grid.Column="3" Content="查看详情" Click="ViewDetails_Click"/><Button Grid.Column="4" Content="查看日志" Margin="8,0,0,0" Click="ViewLog_Click"/><Button Grid.Column="5" Content="加载任务" Style="{StaticResource AccentButtonStyle}" Margin="8,0,0,0" Click="Restore_Click"/>
        </Grid></ScrollViewer>
    </Grid>
</Page>
