<Page
    x:Class="BBDownForWindows.App.Pages.RenameTemplatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BBDownForWindows.App.ViewModels"
    DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16" Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="命名模板" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="管理电影和剧集的文件名字段、顺序与分隔符" Opacity="0.65"/>
                </StackPanel>
                <Button Grid.Column="1" Content="返回重命名" Click="BackToRename_Click" VerticalAlignment="Center"/>
            </Grid>

            <InfoBar IsOpen="{Binding HasMessage}" Visibility="{Binding MessageVisibility}" IsClosable="False" Severity="{Binding MessageSeverity}" Message="{Binding Message}"/>

            <Grid x:Name="TemplateWorkspace" ColumnSpacing="12" RowSpacing="12">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="EditorSecondaryRow" Height="0"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition x:Name="TemplateListColumn" Width="360"/><ColumnDefinition x:Name="TemplateEditorColumn" Width="*"/></Grid.ColumnDefinitions>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="Wide"><VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1050"/></VisualState.StateTriggers></VisualState>
                        <VisualState x:Name="Narrow">
                            <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0"/></VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="TemplateListColumn.Width" Value="*"/>
                                <Setter Target="TemplateEditorColumn.Width" Value="0"/>
                                <Setter Target="EditorSecondaryRow.Height" Value="Auto"/>
                                <Setter Target="TemplateEditorCard.(Grid.Column)" Value="0"/>
                                <Setter Target="TemplateEditorCard.(Grid.Row)" Value="1"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="模板列表" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="新建模板" Click="CreateTemplate_Click"/>
                        </Grid>
                        <ComboBox x:Name="MediaTypeBox" Header="模板类型" ItemsSource="{Binding MediaTypeOptions}" SelectionChanged="MediaTypeBox_SelectionChanged"/>
                        <TextBlock Text="{Binding ActiveTemplateText}" Opacity="0.65"/>
                        <ListView x:Name="TemplateList" ItemsSource="{Binding Templates}" SelectionMode="Single" SelectionChanged="TemplateList_SelectionChanged" MinHeight="360">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:RenameTemplateListItem">
                                    <StackPanel Padding="6" Spacing="3">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Description}" Opacity="0.6" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Pattern}" Opacity="0.5" FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:Name="TemplateEditorCard" Grid.Column="1" Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedTemplateTitle}" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBlock Text="{Binding EditingHint}" Opacity="0.65" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="存在未保存修改" Foreground="{ThemeResource SystemFillColorCautionBrush}" Visibility="{Binding UnsavedChangesVisibility}" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBox Header="模板规则" Text="{Binding TemplatePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" IsEnabled="{Binding HasSelectedTemplate}"/>

                        <StackPanel Spacing="2">
                            <TextBlock Text="示例文件名" Opacity="0.55" FontSize="12"/>
                            <TextBlock Text="{Binding TemplateExample}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="支持的字段" FontWeight="SemiBold"/>
                                        <TextBlock Text="选择一个字段，将它加入右侧的字段顺序" Opacity="0.6" FontSize="12"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="添加所选字段" Click="AddLayoutField_Click" IsEnabled="{Binding HasSelectedTemplate}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid x:Name="FieldPalette" RowSpacing="8" SizeChanged="FieldPalette_SizeChanged"/>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <ComboBox Header="字段分隔符" ItemsSource="{Binding SeparatorOptions}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedSeparator, Mode=TwoWay}"/>
                                <Button Content="应用字段编排" Click="ApplyFieldLayout_Click" IsEnabled="{Binding HasSelectedTemplate}"/>
                                <Button Content="从当前规则重新读取" Click="ReadTemplateFields_Click" IsEnabled="{Binding HasSelectedTemplate}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Padding="8" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <ListView ItemsSource="{Binding TemplateFields}" SelectionMode="None" MinHeight="260">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="4" ColumnSpacing="6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="↑" Tag="{x:Bind}" Click="MoveFieldUp_Click"/>
                                                <Button Grid.Column="2" Content="↓" Tag="{x:Bind}" Click="MoveFieldDown_Click"/>
                                                <Button Grid.Column="3" Content="移除" Tag="{x:Bind}" Click="RemoveField_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="设为当前模板" Click="SetActive_Click" IsEnabled="{Binding CanSetActive}"/>
                            <Button Content="保存修改" Click="SaveChanges_Click" IsEnabled="{Binding CanSaveChanges}" Style="{StaticResource AccentButtonStyle}"/>
                            <Button Content="另存为并应用" Click="SaveAs_Click" IsEnabled="{Binding CanSaveAs}"/>
                            <Button Content="重命名" Click="RenameTemplate_Click" IsEnabled="{Binding CanRename}"/>
                            <Button Content="删除" Click="DeleteTemplate_Click" IsEnabled="{Binding CanDelete}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
