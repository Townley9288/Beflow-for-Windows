<Page x:Class="BBDownForWindows.App.Pages.DownloadHistoryDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:core="using:BBDownForWindows.Core"
      DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Button Content="返回" Click="Back_Click"/>
            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Title}" Style="{StaticResource TitleTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Summary}" Opacity="0.65"/>
            </StackPanel>
        </Grid>
        <Border Grid.Row="1" Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Url}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Timestamp}" VerticalAlignment="Center" Opacity="0.65"/>
            </Grid>
        </Border>
        <Grid Grid.Row="2">
        <ScrollViewer x:Name="EpisodeDetailScroller" Visibility="{Binding DownloadVisibility}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch"><Border Width="{Binding ViewportWidth, ElementName=EpisodeDetailScroller}" MinWidth="900" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid><Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Padding="10,0" ColumnSpacing="10" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="1.7*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.3*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="分集" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="名称" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="视频规格" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="3" Text="音频规格" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="4" Text="输出路径" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="5" Text="状态" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
                <ListView Grid.Row="1" ItemsSource="{Binding Episodes}" SelectionMode="None" HorizontalContentAlignment="Stretch">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:DownloadEpisodeResult">
                            <Grid Padding="10,8" ColumnSpacing="10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="1.7*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.3*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind PageText}" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{x:Bind PageTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{x:Bind VideoText}" TextWrapping="Wrap" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="{x:Bind AudioText}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind RelativeOutputPath}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTipService.ToolTip="{x:Bind RelativeOutputPath}"/>
                                <StackPanel Grid.Column="5" VerticalAlignment="Center"><TextBlock Text="{x:Bind StatusText}" TextWrapping="Wrap"/><TextBlock Text="{x:Bind FallbackReason}" TextWrapping="Wrap" FontSize="11" Foreground="#FFF59E0B"/></StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border></ScrollViewer>
        <ScrollViewer x:Name="DualAudioDetailScroller" Visibility="{Binding DualAudioVisibility}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch"><Border Width="{Binding ViewportWidth, ElementName=DualAudioDetailScroller}" MinWidth="1120" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid><Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Padding="10,0" ColumnSpacing="10" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="76"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="80"/><ColumnDefinition Width="1.5*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="配对" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="来源 A" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="A 规格" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="3" Text="来源 B" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="4" Text="B 规格" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="5" Text="主视频" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="6" Text="延迟" VerticalAlignment="Center" FontWeight="SemiBold"/><TextBlock Grid.Column="7" Text="状态 / 输出" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
                <ListView Grid.Row="1" ItemsSource="{Binding DualAudioPairs}" SelectionMode="None" HorizontalContentAlignment="Stretch">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:DualAudioPairResult">
                            <Grid Padding="10,8" ColumnSpacing="10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="76"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="2.1*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="80"/><ColumnDefinition Width="1.5*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind PairText}" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{x:Bind SourceAPageTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{x:Bind SourceASpecification}" TextWrapping="Wrap" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="{x:Bind SourceBPageTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="{x:Bind SourceBSpecification}" TextWrapping="Wrap" VerticalAlignment="Center"/><TextBlock Grid.Column="5" Text="{x:Bind MainVideoText}" VerticalAlignment="Center"/><TextBlock Grid.Column="6" Text="{x:Bind SourceBDelayMs}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="7" VerticalAlignment="Center"><TextBlock Text="{x:Bind StatusText}" TextWrapping="Wrap"/><TextBlock Text="{x:Bind OutputFile}" TextTrimming="CharacterEllipsis" Opacity="0.6" ToolTipService.ToolTip="{x:Bind OutputFile}"/></StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border></ScrollViewer>
        </Grid>
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalAlignment="Stretch"><StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="查看日志" Click="ViewLog_Click"/><Button Content="打开文件夹" Click="OpenFolder_Click"/><Button Content="加载配置" Click="Load_Click"/><Button Content="重新封装" Visibility="{Binding RemuxVisibility}" IsEnabled="{Binding CanRemux}" Click="Remux_Click"/><Button Content="重试失败集" IsEnabled="{Binding CanRetry}" Click="Retry_Click" Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel></ScrollViewer>
    </Grid>
</Page>
