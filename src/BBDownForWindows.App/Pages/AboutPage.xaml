<Page
    x:Class="BBDownForWindows.App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="LayoutRoot">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Width="{Binding ActualWidth, ElementName=LayoutRoot}" Padding="40" Spacing="20" HorizontalAlignment="Left">
            <Border Padding="28" CornerRadius="16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF7C3AED" Offset="0" />
                        <GradientStop Color="#FF2563EB" Offset="0.55" />
                        <GradientStop Color="#FF0891B2" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="140" Height="140" CornerRadius="32">
                        <Image Source="ms-appx:///Assets/AppIcon.png" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">
                        <TextBlock Text="Beflow for Windows" FontSize="34" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="A Simple Desktop Video Downloader" FontSize="17" Foreground="White" Opacity="0.88" />
                        <TextBlock Text="基于 BBDown 构建的桌面视频下载器图形界面" FontSize="15" Foreground="White" Opacity="0.76" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                            <Border Padding="10,4" CornerRadius="10" Background="#25FFFFFF"><TextBlock Text="WinUI 3" Foreground="White" /></Border>
                            <Border Padding="10,4" CornerRadius="10" Background="#25FFFFFF"><TextBlock Text=".NET 10" Foreground="White" /></Border>
                            <Border Padding="10,4" CornerRadius="10" Background="#25FFFFFF"><TextBlock Text="Windows x64" Foreground="White" /></Border>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="2" Padding="14,7" CornerRadius="14" Background="#2FFFFFFF" VerticalAlignment="Top">
                        <TextBlock x:Name="VersionBadgeText" Text="v1.0.2" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                    </Border>
                </Grid>
            </Border>

            <Border Padding="18" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#182563EB">
                        <FontIcon Glyph="&#xE895;" FontSize="24" Foreground="#FF2563EB" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="软件更新" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="UpdateStatusText" Text="尚未检查更新" TextWrapping="Wrap" />
                        <TextBlock x:Name="LatestVersionText" Opacity="0.65" Visibility="Collapsed" />
                        <ScrollViewer x:Name="ReleaseNotesContainer" MaxHeight="240" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                            <TextBlock x:Name="ReleaseNotesText" Opacity="0.72" TextWrapping="Wrap" LineHeight="24" />
                        </ScrollViewer>
                        <ProgressBar x:Name="UpdateProgress" Minimum="0" Maximum="100" Height="4" Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <HyperlinkButton x:Name="ReleasePageLink" Content="查看发布页" Visibility="Collapsed" />
                        <Button x:Name="CheckUpdateButton" Content="检查更新" Click="CheckUpdate_Click" />
                        <Button x:Name="ApplyUpdateButton" Content="立即更新" Style="{StaticResource AccentButtonStyle}" Click="ApplyUpdate_Click" Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="18" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="5"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border CornerRadius="3" Background="#FF7C3AED" />
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="下载能力" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="• 普通视频、多分P与整季下载&#x0a;• 杜比视界、HDR、4K 至 360P&#x0a;• AVC、HEVC、AV1 与多种音频格式&#x0a;• WEB / TV 扫码登录" TextWrapping="Wrap" LineHeight="25" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Padding="18" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="5"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border CornerRadius="3" Background="#FF0891B2" />
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="增强工作流" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="• aria2c、CDN 节点与多线程&#x0a;• 双链接及奇偶分P双音轨封装&#x0a;• 音轨标签、语言、默认标志与延迟&#x0a;• 历史记录、任务日志与配置恢复" TextWrapping="Wrap" LineHeight="25" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Padding="18" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="50" Height="50" CornerRadius="25" Background="#187C3AED">
                        <FontIcon Glyph="&#xE713;" FontSize="24" Foreground="#FF7C3AED" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="9">
                        <TextBlock Text="运行环境与工具" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Windows App SDK 1.8 · WinUI 3 · .NET 10 自包含 x64" Opacity="0.68" />
                        <Border Padding="14" CornerRadius="8" Background="#100078D4">
                            <TextBlock x:Name="ToolVersions" Text="正在检测工具…" FontFamily="Consolas" TextWrapping="Wrap" LineHeight="23" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Warning"
                Margin="18,0"
                Title="BBDown 上游仓库已归档"
                Message="上游仓库自 2026-05-14 起为只读。现有源码和 Release 仍可使用，但不会再接受官方 Issue、PR 或后续修复；未来若 B 站接口变化，需要由本项目自行兼容或迁移到维护中的分支。" />

            <Border Padding="18" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="项目链接" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="查看 Beflow 源码与发行版本，以及 BBDown 上游项目。" Opacity="0.68" />
                    <Grid ColumnSpacing="18" RowSpacing="4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="Beflow" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <HyperlinkButton Grid.Column="1" Content="项目主页" NavigateUri="https://github.com/Townley9288/Beflow-for-Windows" HorizontalAlignment="Left" Padding="0,4" />
                        <HyperlinkButton Grid.Column="2" Content="Releases" NavigateUri="https://github.com/Townley9288/Beflow-for-Windows/releases" HorizontalAlignment="Left" Padding="0,4" />
                        <TextBlock Grid.Row="1" Text="BBDown 上游" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <HyperlinkButton Grid.Row="1" Grid.Column="1" Content="项目主页" NavigateUri="https://github.com/nilaoda/BBDown" HorizontalAlignment="Left" Padding="0,4" />
                        <HyperlinkButton Grid.Row="1" Grid.Column="2" Content="Releases" NavigateUri="https://github.com/nilaoda/BBDown/releases" HorizontalAlignment="Left" Padding="0,4" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
    </Grid>
</Page>
