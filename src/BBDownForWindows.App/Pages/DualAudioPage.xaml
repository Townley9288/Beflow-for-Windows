<Page x:Class="BBDownForWindows.App.Pages.DualAudioPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Grid Padding="24" ColumnSpacing="20"><Grid.ColumnDefinitions><ColumnDefinition Width="7*"/><ColumnDefinition Width="5*"/></Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"><StackPanel Spacing="16">
            <StackPanel><TextBlock Text="多音轨封装" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="下载两套音轨并批量封装 MKV，或重新封装已有任务" Opacity="0.65"/></StackPanel>
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12">
                <ComboBox Header="来源模式" ItemsSource="{Binding SourceModes}" SelectedItem="{Binding SourceModeText, Mode=TwoWay}" />
                <TextBox Header="主版本 URL" Text="{Binding PrimaryUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="副音轨 URL（奇偶分P模式会忽略）" Text="{Binding SecondaryUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBox Header="分P" Text="{Binding Pages, Mode=TwoWay}" />
                    <ComboBox Grid.Column="1" Header="质量" ItemsSource="{Binding QualityOptions}" SelectedItem="{Binding Quality, Mode=TwoWay}" />
                    <ComboBox Grid.Column="2" Header="编码" ItemsSource="{Binding EncodingOptions}" SelectedItem="{Binding Encoding, Mode=TwoWay}" />
                </Grid>
            </StackPanel></Border>
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12">
                <TextBlock Text="音轨元数据" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Grid ColumnSpacing="12" RowSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBox Header="主音轨名称" Text="{Binding PrimaryLabel, Mode=TwoWay}"/><TextBox Grid.Column="1" Header="副音轨名称" Text="{Binding SecondaryLabel, Mode=TwoWay}"/>
                    <TextBox Grid.Row="1" Header="主音轨语言" Text="{Binding PrimaryLanguage, Mode=TwoWay}"/><TextBox Grid.Row="1" Grid.Column="1" Header="副音轨语言" Text="{Binding SecondaryLanguage, Mode=TwoWay}"/>
                    <ComboBox Grid.Row="2" Header="默认音轨" ItemsSource="{Binding DefaultAudioOptions}" SelectedItem="{Binding DefaultAudio, Mode=TwoWay}"/>
                    <NumberBox Grid.Row="2" Grid.Column="1" Header="副音轨延迟（ms）" Minimum="-10000" Maximum="10000" SmallChange="10" SpinButtonPlacementMode="Inline" Value="{Binding SecondaryAudioDelay, Mode=TwoWay}"/>
                </Grid>
            </StackPanel></Border>
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><StackPanel Spacing="12">
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="输出目录" Text="{Binding WorkDirectory, Mode=TwoWay}"/><Button Grid.Column="1" Content="浏览…" VerticalAlignment="Bottom" Click="BrowseWorkDir_Click"/></Grid>
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="已有任务目录" Text="{Binding ExistingTaskDirectory, Mode=TwoWay}"/><Button Grid.Column="1" Content="浏览…" VerticalAlignment="Bottom" Click="BrowseExisting_Click"/></Grid>
                <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="mkvmerge.exe 路径" Text="{Binding MkvmergePath, Mode=TwoWay}"/><Button Grid.Column="1" Content="选择…" VerticalAlignment="Bottom" Click="BrowseMkvmerge_Click"/></Grid>
                <StackPanel Orientation="Horizontal" Spacing="8"><Button Content="获取规格" Command="{Binding InfoCommand}"/><Button Content="下载并封装" Command="{Binding StartCommand}" Style="{StaticResource AccentButtonStyle}"/><Button Content="仅重新封装" Command="{Binding RemuxCommand}"/><Button Content="取消" Command="{Binding Console.CancelCommand}"/></StackPanel>
            </StackPanel></Border>
        </StackPanel></ScrollViewer>
        <Border Grid.Column="1" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"><Grid RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="多音轨任务日志" Style="{StaticResource SubtitleTextBlockStyle}"/><TextBlock Text="{Binding Console.Status}" Opacity="0.65"/></StackPanel><Button Grid.Column="1" Content="复制" Margin="0,0,8,0" Click="CopyLogs_Click"/><Button Grid.Column="2" Content="清空" Command="{Binding Console.ClearCommand}"/></Grid>
            <TextBox x:Name="LogTextBox" Grid.Row="1" Text="{Binding Console.Logs, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" TextChanged="LogTextBox_TextChanged"/>
        </Grid></Border>
    </Grid>
</Page>
