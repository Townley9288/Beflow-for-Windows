<Page
    x:Class="BBDownForWindows.App.Pages.RenamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:BBDownForWindows.Core"
    xmlns:vm="using:BBDownForWindows.App.ViewModels"
    DataContext="{x:Bind ViewModel, Mode=OneWay}">
    <Page.Resources>
        <DataTemplate x:Key="TmdbResultTemplate" x:DataType="core:TmdbSearchResult">
            <Grid Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="100"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                <Border Width="54" Height="76" CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"><Image Source="{x:Bind PosterUrl}" Stretch="UniformToFill"/></Border>
                <StackPanel Grid.Column="1" Spacing="2"><TextBlock Text="{x:Bind ChineseTitle}" FontWeight="SemiBold"/><TextBlock Text="{x:Bind OriginalTitle}" Opacity="0.65"/><TextBlock Text="{x:Bind Overview}" Opacity="0.55" TextTrimming="CharacterEllipsis" MaxLines="2"/></StackPanel>
                <TextBlock Grid.Column="2" Text="{x:Bind MediaType}" VerticalAlignment="Center" Opacity="0.65"/>
                <TextBlock Grid.Column="3" Text="{x:Bind Year}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <Grid>
    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup>
            <VisualState x:Name="RenameWide"><VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1150"/></VisualState.StateTriggers></VisualState>
            <VisualState x:Name="RenameCompact">
                <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0"/></VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="BasicColumn0.Width" Value="*"/>
                    <Setter Target="BasicColumn1.Width" Value="Auto"/>
                    <Setter Target="BasicColumn2.Width" Value="180"/>
                    <Setter Target="BasicColumn3.Width" Value="0"/>
                    <Setter Target="BasicColumn4.Width" Value="0"/>
                    <Setter Target="BasicSecondaryRow.Height" Value="Auto"/>
                    <Setter Target="SeasonTextBox.(Grid.Row)" Value="1"/>
                    <Setter Target="SeasonTextBox.(Grid.Column)" Value="0"/>
                    <Setter Target="FilenameSuffixBox.(Grid.Row)" Value="1"/>
                    <Setter Target="FilenameSuffixBox.(Grid.Column)" Value="1"/>
                    <Setter Target="FilenameSuffixBox.(Grid.ColumnSpan)" Value="2"/>
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <Button x:Name="FocusSink" Width="1" Height="1" Opacity="0" IsHitTestVisible="False" IsTabStop="True" TabIndex="32767" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    <Grid x:Name="LayoutRoot" Padding="24,16,24,12" RowSpacing="12" SizeChanged="LayoutRoot_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer x:Name="ConfigurationScrollViewer"
                      Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
          <StackPanel Spacing="12">
            <StackPanel>
                <TextBlock Text="重命名" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="通过 TMDB 匹配影视信息，并结合实际媒体规格整理文件名" Opacity="0.65"/>
            </StackPanel>

            <InfoBar IsOpen="{Binding HasMessage}" Visibility="{Binding MessageVisibility}" IsClosable="False" Severity="{Binding MessageSeverity}" Message="{Binding Message}"/>

            <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="文件夹来源" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Text="{Binding DirectoryPath, Mode=OneWay}" PlaceholderText="选择包含视频文件的文件夹" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="选择文件夹…" Click="BrowseFolder_Click"/>
                        <Button Grid.Column="2" Content="重新扫描" Click="ReloadFolder_Click" IsEnabled="{Binding CanReloadDirectory}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="基本信息" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                        <Button x:Name="AdvancedSettingsButton"
                                Grid.Column="1"
                                MinHeight="32"
                                Padding="8,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                IsEnabled="{Binding IsSeries}"
                                Click="AdvancedSettings_Click"
                                AutomationProperties.Name="展开或收起高级设置"
                                ToolTipService.ToolTip="展开或收起集数设置">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding EpisodeSettingsSummary}" Opacity="0.7" VerticalAlignment="Center"/>
                                <FontIcon x:Name="AdvancedSettingsChevron" Glyph="&#xE76C;" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition x:Name="BasicSecondaryRow" Height="0"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition x:Name="BasicColumn0" Width="5*"/><ColumnDefinition x:Name="BasicColumn1" Width="Auto"/><ColumnDefinition x:Name="BasicColumn2" Width="2*"/><ColumnDefinition x:Name="BasicColumn3" Width="2*"/><ColumnDefinition x:Name="BasicColumn4" Width="3*"/></Grid.ColumnDefinitions>
                        <TextBox Header="TMDB 片名" Text="{Binding TmdbQuery, Mode=TwoWay}" PlaceholderText="默认使用文件夹名或下载标题" VerticalAlignment="Bottom"/>
                        <Button x:Name="SearchTmdbButton" Grid.Column="1" Content="搜索 TMDB" Click="SearchTmdb_Click" VerticalAlignment="Bottom"/>
                        <TextBox Grid.Column="2" Header="年份" Text="{Binding Year}" IsReadOnly="True" PlaceholderText="自动获取" VerticalAlignment="Bottom"/>
                        <TextBox x:Name="SeasonTextBox" Grid.Column="3" Header="季数" Text="{Binding SeasonText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSeries}" InputScope="Number" LostFocus="NumericTextBox_LostFocus" VerticalAlignment="Bottom"/>
                        <TextBox x:Name="FilenameSuffixBox" Grid.Column="4" Header="文件名后缀" Text="{Binding FilenameSuffix, Mode=TwoWay}" PlaceholderText="例如 -Beflow" VerticalAlignment="Bottom"/>
                    </Grid>
                    <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Visibility="{Binding TmdbMatchVisibility}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TmdbInfoText}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border x:Name="AdvancedSettingsPanel"
                            Padding="12,8"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            Visibility="Collapsed">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <ToggleSwitch IsOn="{Binding UseCustomEpisodes, Mode=TwoWay}" OnContent="自定义集数" OffContent="自动识别" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="起始集数" VerticalAlignment="Center"/>
                            <TextBox x:Name="StartEpisodeTextBox" Grid.Column="2" Height="32" Text="{Binding StartEpisodeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditCustomEpisodes}" InputScope="Number" LostFocus="NumericTextBox_LostFocus" VerticalContentAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="启用后按当前排序从指定集数连续编号。" Opacity="0.6" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Grid ColumnSpacing="10" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="命名模板" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Templates}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding TemplateExample}" FontFamily="Consolas" Opacity="0.6" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTipService.ToolTip="当前模板的示例文件名"/>
                        <Button Grid.Column="3" Content="管理模板" Click="ManageTemplates_Click" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

            <Grid x:Name="WorkspaceGrid" Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition x:Name="PreviewSecondaryRow" Height="0"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition x:Name="SourceColumn" Width="5*"/><ColumnDefinition x:Name="PreviewColumn" Width="7*"/></Grid.ColumnDefinitions>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WorkspaceWide"><VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1000"/></VisualState.StateTriggers></VisualState>
                        <VisualState x:Name="WorkspaceNarrow">
                            <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0"/></VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SourceColumn.Width" Value="*"/><Setter Target="PreviewColumn.Width" Value="0"/><Setter Target="PreviewSecondaryRow.Height" Value="*"/>
                                <Setter Target="PreviewCard.(Grid.Column)" Value="0"/><Setter Target="PreviewCard.(Grid.Row)" Value="1"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="源文件" Style="{StaticResource SubtitleTextBlockStyle}"/><TextBlock Grid.Column="1" Text="可拖动调整顺序" Opacity="0.55"/></Grid>
                        <ListView Grid.Row="1" ItemsSource="{Binding Files}" CanReorderItems="True" AllowDrop="True" ReorderMode="Enabled" SelectionMode="None" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollMode="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:RenameFileItemViewModel">
                                    <Grid Padding="6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Name}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind EpisodeText}" HorizontalAlignment="Right" Opacity="0.6" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                <Border x:Name="PreviewCard" Grid.Column="1" Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding PreviewTitle}" Style="{StaticResource SubtitleTextBlockStyle}"/><TextBlock Grid.Column="1" Text="{Binding PreviewSummary}" Opacity="0.6"/></Grid>
                        <ListView Grid.Row="1" ItemsSource="{Binding PreviewItems}" SelectionMode="None" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollMode="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="core:RenamePreviewItem">
                                    <StackPanel Padding="6" Spacing="2">
                                        <TextBlock Text="{x:Bind SourceName}" FontFamily="Consolas" Opacity="0.6" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind SourceName}"/>
                                        <TextBlock Text="{x:Bind TargetName}" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap" ToolTipService.ToolTip="{x:Bind TargetName}"/>
                                        <TextBlock Text="{x:Bind DetailText}" Opacity="0.55" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="重命名历史" Click="RenameHistory_Click"/>
                    <Button Content="撤销最近操作" Click="UndoLatest_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="取消当前任务" Command="{Binding Console.CancelCommand}"/>
                    <Button Content="预览重命名" Click="Preview_Click" IsEnabled="{Binding CanPreview}"/>
                    <Button Content="执行重命名" Click="Execute_Click" IsEnabled="{Binding CanExecutePreview}" Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>
            </Grid>
    </Grid>
    </Grid>
</Page>
