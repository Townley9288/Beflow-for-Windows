<UserControl
    x:Class="BBDownForWindows.App.Controls.RenameHistoryDetailContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BBDownForWindows.App.ViewModels"
    DataContext="{x:Bind ViewModel, Mode=OneTime}">
    <Grid RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Text="{Binding Title}" Style="{StaticResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding HeaderSubtitle}" Opacity="0.65" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Border Grid.Column="1" Padding="12,5" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Center">
                <TextBlock Text="{Binding StateText}" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Padding="14" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid ColumnSpacing="20" RowSpacing="12">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                <StackPanel Spacing="3"><TextBlock Text="中文片名" Opacity="0.55"/><TextBlock Text="{Binding ChineseTitleText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/></StackPanel>
                <StackPanel Grid.Column="1" Spacing="3"><TextBlock Text="原始片名" Opacity="0.55"/><TextBlock Text="{Binding EnglishTitleText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/></StackPanel>
                <StackPanel Grid.Column="2" Spacing="3"><TextBlock Text="媒体类型" Opacity="0.55"/><TextBlock Text="{Binding MediaTypeText}" FontWeight="SemiBold"/></StackPanel>

                <StackPanel Grid.Row="1" Spacing="3"><TextBlock Text="年份" Opacity="0.55"/><TextBlock Text="{Binding YearText}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3"><TextBlock Text="季数" Opacity="0.55"/><TextBlock Text="{Binding SeasonText}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="3"><TextBlock Text="命名模板" Opacity="0.55"/><TextBlock Text="{Binding TemplateText}" TextTrimming="CharacterEllipsis"/></StackPanel>

                <StackPanel Grid.Row="2" Spacing="3"><TextBlock Text="执行时间" Opacity="0.55"/><TextBlock Text="{Binding CreatedAtText}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="3"><TextBlock Text="撤销时间" Opacity="0.55"/><TextBlock Text="{Binding UndoneAtText}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Spacing="3"><TextBlock Text="变更数量" Opacity="0.55"/><TextBlock Text="{Binding OperationCountText}"/></StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Spacing="6">
            <TextBlock Text="文件夹来源" FontWeight="SemiBold"/>
            <Border Padding="12,9" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Grid ColumnSpacing="9">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8B7;" FontSize="15" Opacity="0.65" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding DirectoryPath}" FontFamily="Consolas" TextWrapping="Wrap" ToolTipService.ToolTip="{Binding DirectoryPath}"/>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="文件名变更" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Grid.Column="1" Text="{Binding OperationSummary}" Opacity="0.6" VerticalAlignment="Center"/>
        </Grid>

        <ListView Grid.Row="4"
                  ItemsSource="{Binding Operations}"
                  SelectionMode="None"
                  HorizontalContentAlignment="Stretch"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollMode="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RenameHistoryOperationDetailViewModel">
                    <Border Padding="12,10" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind SequenceText}" FontFamily="Consolas" Opacity="0.5" VerticalAlignment="Top"/>
                            <Grid Grid.Column="1" RowSpacing="4">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="原文件" Opacity="0.55"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind SourceName}" FontFamily="Consolas" Opacity="0.7" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind SourcePath}"/>
                                <TextBlock Grid.Row="1" Text="新文件" Opacity="0.55"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind TargetName}" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap" ToolTipService.ToolTip="{x:Bind TargetPath}"/>
                            </Grid>
                            <Border Grid.Column="2" Padding="9,3" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" VerticalAlignment="Top">
                                <TextBlock Text="{x:Bind KindText}" FontSize="12"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
