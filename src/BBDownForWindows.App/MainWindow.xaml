<Window
    x:Class="BBDownForWindows.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="WindowRoot" Background="{ThemeResource BeflowWindowBackgroundBrush}">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <InfoBar x:Name="UpdateInfoBar" IsOpen="False" IsClosable="True" Severity="Informational" Title="发现 Beflow 新版本">
        <InfoBar.ActionButton><Button Content="查看更新" Click="UpdateInfoBar_Click"/></InfoBar.ActionButton>
    </InfoBar>
    <NavigationView Grid.Row="1" x:Name="RootNavigation" Background="{ThemeResource BeflowWindowBackgroundBrush}" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" PaneDisplayMode="LeftCompact" ItemInvoked="RootNavigation_ItemInvoked" Loaded="RootNavigation_Loaded">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="下载" Tag="download" Icon="Download" />
            <NavigationViewItem Content="多音轨封装" Tag="dual" Icon="Document" />
            <NavigationViewItem Content="历史" Tag="history" Icon="Clock" />
            <NavigationViewItem Content="设置" Tag="settings" Icon="Setting" />
            <NavigationViewItem Content="关于" Tag="about">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE946;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.PaneFooter>
            <Button x:Name="ThemeButton" Width="40" Height="40" Margin="4,0,0,8" Padding="0" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" AutomationProperties.Name="选择界面主题">
                <FontIcon x:Name="ThemeIcon" Glyph="&#xE771;" FontSize="18" />
                <Button.Flyout>
                    <MenuFlyout Placement="TopEdgeAlignedLeft">
                        <RadioMenuFlyoutItem x:Name="SystemThemeItem" Text="跟随系统" GroupName="ThemeMode" Tag="system" Click="ThemeMenuItem_Click" />
                        <RadioMenuFlyoutItem x:Name="LightThemeItem" Text="浅色" GroupName="ThemeMode" Tag="light" Click="ThemeMenuItem_Click" />
                        <RadioMenuFlyoutItem x:Name="DarkThemeItem" Text="深色" GroupName="ThemeMode" Tag="dark" Click="ThemeMenuItem_Click" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </NavigationView.PaneFooter>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
    </Grid>
</Window>
